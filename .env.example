# Public — shipped in web/RN client bundles.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Secret — bypasses RLS. Used by Claude sessions for schema introspection
# and admin SQL via the PostgREST endpoint. Never ship this to a client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Management API PAT — for DDL and arbitrary SQL via
# POST https://api.supabase.com/v1/projects/{ref}/database/query.
# Generate + revoke at https://supabase.com/dashboard/account/tokens.
SUPABASE_MANAGEMENT_PAT=sbp_...
SUPABASE_PROJECT_REF=your-project-ref
